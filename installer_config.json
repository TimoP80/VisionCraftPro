  "python_min": "3.9",
  "python_download_url": "https://www.python.org/downloads/",
  "install_dir": "C:\\Program Files\\VisionCraftPro",
  "exe_name": "run.bat",
  "launcher": "run.bat",
  "setup_script": "vcp_setup.py",
  "license_file": "LICENSE.txt",
  "output_exe": "VisionCraftPro_Setup_1.3.0.exe",
  "dependencies": [
    "requirements.txt"
